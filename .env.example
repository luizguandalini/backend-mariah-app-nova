# ============================================================
# .env.example - Template de variáveis de ambiente
# ============================================================
# Copie para .env (dev local) ou .env.prod (produção) e preencha.
#   cp .env.example .env
#
# Convenção: variáveis com prefixo DEV_ valem em desenvolvimento e
# PROD_ em produção (NODE_ENV decide o prefixo). Variáveis sem prefixo
# valem para os dois ambientes.
# ============================================================

# development | production
NODE_ENV=development
PORT=3000

# ------------------------------------------------------------
# Frontend / CORS
# ------------------------------------------------------------
DEV_FRONTEND_URL=http://localhost:5173
PROD_FRONTEND_URL=https://mariah.com.br

# ------------------------------------------------------------
# Túnel SSH para o RDS (somente quando o banco está na AWS)
# Em dev local com Postgres no Docker, deixe SSH_ENABLED=false.
# ------------------------------------------------------------
SSH_ENABLED=false
# SSH_HOST=98.81.229.161
# SSH_PORT=22
# SSH_USERNAME=ec2-user
# SSH_PRIVATE_KEY_PATH=./chave.pem
# DB_TUNNEL_LOCAL_PORT=5432
# DB_RDS_HOST=xxxxx.rds.amazonaws.com
# DB_RDS_PORT=5432

# ------------------------------------------------------------
# Banco de dados
# DEV  -> Postgres local no Docker (docker-compose.yml)
# PROD -> RDS (use as variáveis PROD_*)
# ------------------------------------------------------------
DEV_DB_HOST=localhost
DEV_DB_PORT=5432
DEV_DB_USERNAME=mariah
DEV_DB_PASSWORD=mariah2026
DEV_DB_DATABASE=mariah
DEV_DB_SYNCHRONIZE=true
DEV_DB_SSL=false

# PROD_DB_HOST=xxxxx.rds.amazonaws.com
# PROD_DB_PORT=5432
# PROD_DB_USERNAME=
# PROD_DB_PASSWORD=
# PROD_DB_DATABASE=
# PROD_DB_SYNCHRONIZE=false
# PROD_DB_SSL=true

# ------------------------------------------------------------
# Autenticação - gere um valor aleatório:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET=troque-este-valor

# ------------------------------------------------------------
# RabbitMQ
# ------------------------------------------------------------
RABBITMQ_URL=amqp://mariah:mariah2026@localhost:5672

# ------------------------------------------------------------
# Armazenamento de imagens (S3)
# DEV  -> MinIO local (S3_ENDPOINT preenchido)
# PROD -> S3 da AWS (deixe S3_ENDPOINT vazio/ausente)
# ------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_NAME=mariah-app-uploads-dev
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mariahdev
AWS_SECRET_ACCESS_KEY=mariahdev123

# ------------------------------------------------------------
# OpenAI
# Em dev, deixe vazio para usar a legenda de teste (sem custo/sem chamada real).
# Em prod, a chave costuma ser gravada via painel (Configurações IA),
# mas também pode ser definida aqui.
# ------------------------------------------------------------
# OPENAI_API_KEY=

# ------------------------------------------------------------
# Usuário DEV inicial (seed automático)
# ------------------------------------------------------------
DEV_NAME=Dev Mariah
DEV_EMAIL=dev@mariah.local
DEV_PASSWORD=dev123456
